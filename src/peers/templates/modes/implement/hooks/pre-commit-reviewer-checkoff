#!/bin/sh
# Pre-commit hook: early warning for reviewer-only checkoffs (implement-mode).
#
# Rejects commits where the same peer that implemented a step's
# `touches:` files is also marking the step `[x]` in PLAN.md.
#
# SCOPE: this hook is a cheap EARLY WARNING, not the security
# boundary. It runs inside the agent's own `git commit`, so the *current*
# committer identity it sees (PEERS_PEER_NAME, git author) is agent-influenced
# and best-effort. The authoritative check is the post-hoc
# `checkoff_by_other_peer` gate, which the orchestrator runs between ticks
# (no live agent) and which keys identity off the substrate-written
# `peers-attest` git note (the tick HEAD-delta attribution the agent cannot
# forge). For the IMPLEMENTATION side this hook DOES consult that note, so a
# forged `Peer:` trailer on an already-attested impl commit is caught here too.
set -e

# 1. Did this commit touch PLAN.md?
if ! git diff --cached --name-only | grep -qx PLAN.md; then
  exit 0  # no PLAN.md change, no-op
fi

# 2+. Delegate parsing/enforcement to embedded Python (robust diff/PLAN parser)
python3 - <<'PYEOF'
import re
import subprocess
import sys
import pathlib

diff = subprocess.run(
    ["git", "diff", "--cached", "--", "PLAN.md"],
    capture_output=True, text=True,
).stdout

# Parse step ID from removed-then-added pairs
removed_open = set()   # STEP-N that was [ ]
added_done = set()     # STEP-N that became [x]
step_pattern = re.compile(r"^([+-])\s*-\s*\[([ xX])\]\s*\[(STEP-\d+)\]")
for line in diff.splitlines():
    m = step_pattern.match(line)
    if m:
        sign, mark, sid = m.groups()
        if sign == "-" and mark == " ":
            removed_open.add(sid)
        elif sign == "+" and mark in ("x", "X"):
            added_done.add(sid)

checkoffs = removed_open & added_done
if not checkoffs:
    sys.exit(0)

# Read CURRENT (staged) PLAN.md to find touches: for each checked-off step.
# Use the index version so we see what's about to be committed.
plan_text = subprocess.run(
    ["git", "show", ":PLAN.md"],
    capture_output=True, text=True,
).stdout
if not plan_text:
    # Fallback to working tree
    try:
        plan_text = pathlib.Path("PLAN.md").read_text()
    except OSError:
        plan_text = ""

# Build per-step sub-attr blocks: lines starting with two-space indent following
# the step header.
step_blocks = {}
current_id = None
header_re = re.compile(r"^- \[[ xX]\] \[(STEP-\d+)\]")
for line in plan_text.splitlines():
    m = header_re.match(line)
    if m:
        current_id = m.group(1)
        step_blocks[current_id] = []
    elif current_id is not None and line.startswith("  -"):
        step_blocks[current_id].append(line)
    elif current_id is not None and line and not line.startswith(" "):
        # Block ended (new top-level item or blank-separated section)
        current_id = None

touches_re = re.compile(r"^\s*-\s*touches:\s*(.+?)\s*$")

import os

# Identify the CURRENT committer by peer name, not git author email. Both
# peers usually commit under one shared container git identity, so an email
# comparison cannot tell them apart. The orchestrator exports PEERS_PEER_NAME
# into each peer's process; the hook (a child of that process) inherits it.
# Fall back to the git author email when the env var is absent (e.g. a
# hand-made commit outside the loop).
_peer_env = os.environ.get("PEERS_PEER_NAME", "").strip()
current_email = subprocess.run(
    ["git", "config", "user.email"],
    capture_output=True, text=True,
).stdout.strip()
current_ids = set()
if _peer_env:
    current_ids.add(f"peer:{_peer_env.lower()}")
if current_email:
    current_ids.add(f"email:{current_email}")

_peer_trailer_re = re.compile(r"^Peer:[ \t]*(\S+)[ \t]*$")
_trailer_line_re = re.compile(r"^[A-Za-z][A-Za-z0-9-]*:[ \t]*.*$")


def _peer_identity_from_trailers(body):
    """Return the final trailer-block Peer identity, if present."""
    lines = [line.rstrip("\r") for line in body.rstrip().splitlines()]
    for line in reversed(lines):
        if line.strip() == "":
            break
        m = _peer_trailer_re.match(line)
        if m:
            return f"peer:{m.group(1).lower()}"
        if not _trailer_line_re.match(line):
            break
    return ""


def _attested_peer(sha):
    """Substrate-attested peer for ``sha`` from the ``peers-attest`` git note,
    or "" when none. BUG-142: this note is the agent-unforgeable identity
    (derived from the tick HEAD-delta by the orchestrator), so it OVERRIDES the
    agent-authored ``Peer:`` trailer on the implementation commit."""
    r = subprocess.run(
        ["git", "notes", "--ref=peers-attest", "show", sha],
        capture_output=True, text=True,
    )
    if r.returncode != 0:
        return ""
    return r.stdout.strip()


def _impl_identity(path):
    """Peer identity of the last commit that modified ``path``.

    Priority: substrate ``peers-attest`` note (authoritative) > ``Peer:``
    trailer > email:<author>."""
    sha = subprocess.run(
        ["git", "log", "-1", "--format=%H", "--", path],
        capture_output=True, text=True,
    ).stdout.strip()
    if not sha:
        return ""
    note = _attested_peer(sha)
    if note:
        return f"peer:{note.lower()}"
    body = subprocess.run(
        ["git", "log", "-1", "--format=%B", sha],
        capture_output=True, text=True,
    ).stdout
    peer_id = _peer_identity_from_trailers(body)
    if peer_id:
        return peer_id
    ae = subprocess.run(
        ["git", "log", "-1", "--format=%ae", sha],
        capture_output=True, text=True,
    ).stdout.strip()
    return f"email:{ae}" if ae else ""


def _file_signers(path):
    """Reviewers who signed any line of ``path`` in .peers/justifications.log."""
    out = set()
    try:
        text = pathlib.Path(".peers/justifications.log").read_text()
    except OSError:
        return out
    for line in text.splitlines():
        parts = line.split(" ", 3)
        if len(parts) < 4:
            continue
        _chain, file_line, reviewer, _reason = parts
        fpath, sep, _lno = file_line.rpartition(":")
        if sep and fpath == path:
            out.add(reviewer)
    return out


def _independently_reviewed(tf, impl_id):
    """True if some justification signer for ``tf`` is a peer OTHER than the
    file's implementer (mirrors the post-hoc gate's BUG-009 fix). Only honored
    for peer-identified implementers; email-only legacy commits get no escape.
    """
    if not impl_id.startswith("peer:"):
        return False
    return any(
        f"peer:{signer.lower()}" != impl_id for signer in _file_signers(tf)
    )


violations = []
for sid in sorted(checkoffs):
    block = step_blocks.get(sid, [])
    touches_files = []
    for sub in block:
        m = touches_re.match(sub)
        if m:
            raw = m.group(1).strip()
            # Strip optional [list] / [a, b] wrappers
            raw = raw.strip("[]")
            for f in raw.split(","):
                f = f.strip().strip("\"'")
                if f:
                    touches_files.append(f)
    if not touches_files:
        print(
            f"warn: {sid} marked [x] but has no touches: — cannot enforce "
            "reviewer-only-checkoff",
            file=sys.stderr,
        )
        continue
    for tf in touches_files:
        impl_id = _impl_identity(tf)
        if not impl_id:
            # File new in this commit or not yet tracked — can't enforce
            continue
        if impl_id not in current_ids:
            # Committed by a different peer than the file's author = reviewed.
            continue
        # committer authored this file (the norm for co-implemented
        # steps). Allow only if the OTHER peer signed an independent review in
        # .peers/justifications.log — otherwise it is a self-bless.
        if _independently_reviewed(tf, impl_id):
            continue
        violations.append((sid, tf, impl_id, current_ids))

if violations:
    print("REJECTED: reviewer-only-checkoff violation", file=sys.stderr)
    for sid, tf, la, identities in violations:
        print(f"  {sid}: file {tf} was last modified by {la}", file=sys.stderr)
        print(
            "         current committer matches "
            f"{', '.join(sorted(identities))} — cannot checkoff own work",
            file=sys.stderr,
        )
    print(
        "  hint: implement-mode requires the OTHER peer to mark steps [x] "
        "after review",
        file=sys.stderr,
    )
    sys.exit(1)

sys.exit(0)
PYEOF
